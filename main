# Getting user input
a = int(input("Number 1:\t"))
b = int(input("Number 2:\t"))
operation = input("Operation (+, -, *, /):\t")

# Processing the operation
if operation == "+":
    print("Result:", a + b)
elif operation == "-":
    print("Result:", a - b)
elif operation == "*":
    print("Result:", a * b)
elif operation == "/":
    if b != 0:
        print("Result:", a / b)
    else:
        print("Error: Division by zero is not allowed.")
else:
    print("Error: Invalid operation selected.")
